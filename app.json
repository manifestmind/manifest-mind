{
  "expo": {
    "name": "manifestmind",
    "slug": "manifestmind",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icons/icon-1024.png",
    "scheme": "manifestmind",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.manifestmind.app",
      "googleServicesFile": "./GoogleService-Info.plist",
      "associatedDomains": ["applinks:manifestmind.firebaseapp.com"]
    },
    "android": {
      "package": "com.manifestmind.app",
      "googleServicesFile": "./google-services.json",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [{ "scheme": "https", "host": "manifestmind.firebaseapp.com" }],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "adaptiveIcon": {
        "backgroundColor": "#6B3FA0",
        "foregroundImage": "./assets/icons/adaptive-foreground-1024.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./public/icons/favicon-32.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-font",
        {
          "fonts": [
            "https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&display=swap",
            "https://fonts.googleapis.com/css2?family=Jost:wght@300;400;500&display=swap"
          ]
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": false,
      "reactCompiler": true
    }
  }
}
